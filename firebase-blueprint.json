{
  "entities": {
    "User": {
      "title": "User",
      "description": "Secure profiles containing user preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "UUID of the user" },
        "email": { "type": "string", "format": "email" },
        "currency": { "type": "string", "description": "e.g., MDL, EUR, USD" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "currency", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Personalized transaction categories.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": ["string", "null"], "description": "null if default system category" },
        "name": { "type": "string" },
        "color": { "type": "string", "description": "HEX color code" },
        "icon": { "type": "string" }
      },
      "required": ["id", "name", "color", "icon"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial operations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["INCOME", "EXPENSE"] },
        "categoryId": { "type": "string" },
        "accountId": { "type": ["string", "null"] },
        "originalAmount": { "type": ["number", "null"] },
        "originalCurrency": { "type": ["string", "null"] },
        "exchangeRate": { "type": ["number", "null"] },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" }
      },
      "required": ["id", "userId", "amount", "type", "categoryId", "date", "description"]
    },
    "Account": {
      "title": "Account",
      "description": "User financial accounts.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "userId", "currency", "createdAt"]
    },
    "Subscription": {
      "title": "Subscription",
      "description": "Recurring transactions.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "categoryId": { "type": "string" },
        "accountId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "nextBillingDate": { "type": "string", "format": "date-time" },
        "frequency": { "type": "string", "enum": ["MONTHLY", "WEEKLY", "YEARLY"] },
        "notifyDaysBefore": { "type": "number" },
        "lastProcessedDate": { "type": ["string", "null"], "format": "date-time" }
      },
      "required": ["id", "userId", "name", "amount", "currency", "categoryId", "accountId", "startDate", "nextBillingDate", "frequency", "notifyDaysBefore"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles collection"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Categories collection"
    },
    "/transactions/{transactionId}": {
      "schema": { "$ref": "#/entities/Transaction" },
      "description": "Transactions collection"
    },
    "/accounts/{accountId}": {
      "schema": { "$ref": "#/entities/Account" },
      "description": "Accounts collection"
    },
    "/subscriptions/{subscriptionId}": {
      "schema": { "$ref": "#/entities/Subscription" },
      "description": "Subscriptions collection"
    }
  }
}
